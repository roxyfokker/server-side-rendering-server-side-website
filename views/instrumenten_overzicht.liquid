{%  render 'partials/head.liquid', title: "Instrumenten overzicht" %}
{% include 'partials/header.liquid', path: path %}

<nav class="overview-nav">
    <ul>
        <li><a class="{% if type == nil %}active{% endif %}" href="/instrumenten">Alles</a></li>
        <li><a class="{% if type == 'gitaar' %}active{% endif %}" href="/instrumenten?type=gitaar">Gitaar</a></li>
        <li><a class="{% if type == 'keyboard' %}active{% endif %}" href="/instrumenten?type=keyboard">Keyboard</a></li>
        <li><a class="{% if type == 'viool' %}active{% endif %}" href="/instrumenten?type=viool">Viool</a></li>
        <li><a class="{% if type == 'blaasinstrument' %}active{% endif %}" href="/instrumenten?type=blaasinstrument">Blaasinstrument</a></li>
        <li><a class="{% if type == 'drums' %}active{% endif %}" href="/instrumenten?type=drums">Drums</a></li>
    </ul>
</nav>

<table class="instrument-overview">
    <caption>Overzicht van instrumenten</caption>

    <thead>
        <tr>
            <th scope="col">Naam isntrument</th>
            <th scope="col">merk</th>
            <th scope="col">type</th>
            <th scope="col">serienummer</th>
            <th scope="col">status</th> 
        </tr>
    </thead>

    <tbody>
        {% for instrument in instruments %}
        <tr>
            <td scope="row"><a href="/instruments/{{ instrument.id }}">{{ instrument.name }}</a></td><!--tijdelijk ik wil css overlay maken-->
            <td>{{ instrument.brand | default: "Onbekend" }}</td>
            <td>{{ instrument.type | default: "Onbekend" }}</td>
            <td>{{ instrument.serial_number | default: "Onbekend" }}</td>
            <td>{{ instrument.status | default: "Onbekend" }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

{% render 'partials/foot.liquid' %}